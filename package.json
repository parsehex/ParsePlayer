{
  "name": "parseplayer",
  "version": "1.0.0",
  "description": "ParsePlayer — Modern LCD Music Manager",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "backend": "sh ./start.sh",
    "frontend": "npm run dev -w frontend -- --host",
    "frontend:build": "npm run build -w frontend",
    "dev": "concurrently --kill-others \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
