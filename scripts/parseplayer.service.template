[Unit]
Description=ParsePlayer Flask service
After=network.target

[Service]
Type=simple
User=__APP_USER__
Group=__APP_GROUP__
WorkingDirectory=__APP_DIR__
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/etc/default/parseplayer
ExecStart=__APP_DIR__/venv/bin/gunicorn -w 1 -b 0.0.0.0:__APP_PORT__ app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
